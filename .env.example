# Database
DATABASE_URL=your_postgres_connection_string

# Plaid Banking Integration (Required for real bank connections)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key
PLAID_ENV=sandbox  # or 'production' for live banking

# Credit Bureau Integrations (Choose one or more)

# Option 1: Direct Experian Integration
EXPERIAN_CLIENT_ID=your_experian_client_id
EXPERIAN_CLIENT_SECRET=your_experian_client_secret
EXPERIAN_API_URL=https://api.experian.com

# Option 2: CRS Credit API (Multi-bureau access)
CRS_CREDIT_API_KEY=your_crs_api_key

# Option 3: iSoftpull (Soft credit pulls)
ISOFTPULL_API_KEY=your_isoftpull_api_key

# Optional: AI Features
OPENAI_API_KEY=your_openai_api_key

# Application
BASE_URL=https://your-app-domain.replit.app
NODE_ENV=development