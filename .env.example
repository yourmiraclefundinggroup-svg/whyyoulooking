# Database
DATABASE_URL=your_postgres_connection_string

# Plaid Banking Integration (Required for real bank connections)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key
PLAID_ENV=sandbox  # or 'production' for live banking

# Credit Bureau Integrations (Choose one or more)

# Option 1: Direct Experian Integration
# Register at https://developer.experian.com/
EXPERIAN_CLIENT_ID=your_experian_client_id
EXPERIAN_CLIENT_SECRET=your_experian_client_secret
EXPERIAN_API_URL=https://sandbox-us-api.experian.com

# USPS API Configuration (New OAuth 2.0 API)
# Register at https://developer.usps.com/
USPS_CLIENT_ID=your_usps_client_id_here
USPS_CLIENT_SECRET=your_usps_client_secret_here

# Option 2: CRS Credit API (Multi-bureau access)
CRS_CREDIT_API_KEY=your_crs_api_key

# Option 3: iSoftpull (Soft credit pulls)
ISOFTPULL_API_KEY=your_isoftpull_api_key

# Optional: AI Features
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Lob.com — Automated Mail API for Dispute Letter Sending
# Replaces manual certified mail. Register at https://lob.com/
# Provides USPS tracking, certified mail, and delivery confirmation.
LOB_API_KEY=your_lob_api_key

# Stripe Payments
STRIPE_SECRET_KEY=your_stripe_secret_key
VITE_STRIPE_PUBLIC_KEY=your_stripe_publishable_key

# Application
BASE_URL=https://scoreshiftapp.com
NODE_ENV=development
